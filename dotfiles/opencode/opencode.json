{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "asana": {
      "type": "local",
      "command": ["npx", "-y", "@roychri/mcp-server-asana"],
      "enabled": true,
      "environment": {
        "ASANA_ACCESS_TOKEN": "{env:ASANA_ACCESS_TOKEN}"
      }
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "{env:OBSIDIAN_VAULT_PATH}"
      ],
      "enabled": true
    }
  },
  "tools": {
    "asana_*": false,
    "obsidian_*": false
  }
}
