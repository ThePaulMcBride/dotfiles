{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "asana": {
      "type": "local",
      "command": ["npx", "-y", "@roychri/mcp-server-asana"],
      "enabled": true,
      "environment": {
        "ASANA_ACCESS_TOKEN": "{env:ASANA_ACCESS_TOKEN}"
      }
    }
  },
  "tools": {
    "asana_*": false
  }
}
